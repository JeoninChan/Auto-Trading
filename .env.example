# =============================================
# 주식 자동 매매 트레이딩 시스템 환경 변수
# 이 파일을 .env로 복사 후 실제 값 입력
# =============================================

# 키움 REST API (한국 단타)
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# KIS API - 실거래 (미국 ETF 단타)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=               # 계좌번호 (숫자만)
KIS_ACCOUNT_SUFFIX=01         # 계좌 상품코드

# KIS API - 모의투자
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=

# DART API (한국 재무제표·공시)
DART_API_KEY=                  # https://opendart.fss.or.kr 에서 무료 발급

# AI API (텐버거 분석)
ANTHROPIC_API_KEY=             # Claude API
GEMINI_API_KEY=                # Google Gemini
GROK_API_KEY=                  # xAI Grok
OPENAI_API_KEY=                # GPT-4

# 설정
LOG_LEVEL=INFO
DATA_DIR=./data/datasets
REPORT_DIR=./ten_bagger/reports
BLACKLIST_PATH=./blacklist/blacklist.json
